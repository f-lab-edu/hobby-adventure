<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jian.hobbyadventure.repository.UserExplorationMapper">

    <select id="findAllByCondition" resultType="com.jian.hobbyadventure.domain.UserExploration">
        SELECT * FROM user_explorations
        <where>
            user_id = #{userId}
            AND status = #{status}
            <if test="explorationIds != null">
                AND exploration_id IN
                <foreach collection="explorationIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
        <choose>
            <when test="status.name() == 'STARTED'">ORDER BY created_at DESC</when>
            <otherwise>ORDER BY completed_at DESC</otherwise>
        </choose>
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*) FROM user_explorations
        <where>
            user_id = #{userId}
            AND status = #{status}
            <if test="explorationIds != null">
                AND exploration_id IN
                <foreach collection="explorationIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
    </select>

</mapper>
